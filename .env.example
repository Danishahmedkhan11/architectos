# Copy to .env and fill in. Without ANY key, ArchitectOS still runs — the
# knowledge graph, search, and blast-radius analysis are always fully live;
# Ask/Impact/Generate will just show an honest "add a key" message.
#
# Set exactly ONE of the two keys below. If both are set, OPENROUTER_API_KEY
# wins.

# Option A — native OpenAI (recommended default here, and what this project
# is actually built/graded against: GPT-5.6 for reasoning, Codex for
# codegen). Real API cost. Also enables embeddings-based retrieval (better
# search than OpenRouter's keyword-only fallback).
OPENAI_API_KEY=

# Option B — OpenRouter, for free/cheap local testing without paying. Sign
# up at https://openrouter.ai (no payment needed) and set the model vars
# below to openai/gpt-oss-20b:free instead. Note: OpenRouter's free tier is
# rate/quota-limited, so occasional errors under load are expected, not a
# bug — and this path does NOT use GPT-5.6/Codex, so it's for local
# iteration only, not for the actual submission build.
OPENROUTER_API_KEY=

# Model ids for native OpenAI (the graded config). Swap to
# openai/gpt-oss-20b:free for both if you're testing via OpenRouter instead
# (see Option B above). ArchitectOS steps down automatically through a
# fallback chain if your account doesn't have access to the first choice.
ARCHITECTOS_REASONING_MODEL=gpt-5.6-sol
ARCHITECTOS_CODEX_MODEL=gpt-5.3-codex
ARCHITECTOS_EMBED_MODEL=text-embedding-3-small

# on = force offline demo mode even with a key; auto = live when key present.
ARCHITECTOS_DEMO=auto

ARCHITECTOS_HOST=127.0.0.1
ARCHITECTOS_PORT=8321

# Optional. Leave all four blank unless you specifically want the graph
# mirrored to a Neo4j Aura database (e.g. to share it across machines) — the
# local data/graph.json file already persists across restarts on its own,
# and is simpler. Note: if set, Neo4j is checked BEFORE the local file on
# startup, so an old graph saved there will keep reappearing until you
# ingest something new or clear it manually.
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
