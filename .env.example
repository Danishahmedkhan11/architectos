# Copy to .env and fill in. Without ANY key, ArchitectOS still runs — the
# knowledge graph, search, and blast-radius analysis are always fully live;
# Ask/Impact/Generate will just show an honest "add a key" message.
#
# Set exactly ONE of the two keys below. If both are set, OPENROUTER_API_KEY
# wins.

# Option A — free, good for just trying the app out. Sign up at
# https://openrouter.ai (no payment needed) and set the model vars below to
# openai/gpt-oss-20b:free. Note: OpenRouter's free tier is rate/quota-limited,
# so occasional errors under load are expected, not a bug.
OPENROUTER_API_KEY=

# Option B — native OpenAI, best quality, real API cost. Also enables
# embeddings-based retrieval (better search than OpenRouter's keyword-only
# fallback).
OPENAI_API_KEY=

# Model ids. For OpenRouter, use openai/gpt-oss-20b:free (free) or any other
# id from https://openrouter.ai/models. For native OpenAI, use real model
# names like gpt-4o. ArchitectOS steps down automatically through a fallback
# chain if your account doesn't have access to the first choice.
ARCHITECTOS_REASONING_MODEL=openai/gpt-oss-20b:free
ARCHITECTOS_CODEX_MODEL=openai/gpt-oss-20b:free
ARCHITECTOS_EMBED_MODEL=text-embedding-3-small

# on = force offline demo mode even with a key; auto = live when key present.
ARCHITECTOS_DEMO=auto

ARCHITECTOS_HOST=127.0.0.1
ARCHITECTOS_PORT=8321

# Optional. Leave all four blank unless you specifically want the graph
# mirrored to a Neo4j Aura database (e.g. to share it across machines) — the
# local data/graph.json file already persists across restarts on its own,
# and is simpler. Note: if set, Neo4j is checked BEFORE the local file on
# startup, so an old graph saved there will keep reappearing until you
# ingest something new or clear it manually.
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
